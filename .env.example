# ──────────────────────────────────────────────
# RAG Pipeline — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# LLM Provider
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Database (override if not using docker-compose)
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag_pipeline
DATABASE_URL_SYNC=postgresql://rag:rag@localhost:5432/rag_pipeline

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.7

# Application
DEBUG=false
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50
